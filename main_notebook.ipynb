import pandas as pd
import networkx as nx
import networkx as nx
from networkx.algorithms import community
# 1. Load the data
df = pd.read_csv('hero-network.csv')

# 2. Filter out self-loops (where hero1 == hero2)
df_clean = df[df['hero1'] != df['hero2']]

# 3. Build the graph
G = nx.from_pandas_edgelist(df_clean, 'hero1', 'hero2')

# 4. Confirm the structure
print(f"Graph successfully built with {G.number_of_nodes()} heroes and {G.number_of_edges()} interactions.")


print("Calculating Centrality Measures...")

# 1. Degree Centrality (simple, fast)
degree_cent = nx.degree_centrality(G)

# 2. PageRank (global influence)
pagerank = nx.pagerank(G)

# 3. Betweenness Centrality (bridge nodes - this may take some time)
# We use k=None to calculate for all nodes, but if it's too slow, 
# we can use k=1000 to sample nodes and speed it up.
betweenness = nx.betweenness_centrality(G, k=1000) 

# Convert to DataFrame for easy viewing
centrality_df = pd.DataFrame({
    'Degree': degree_cent,
    'PageRank': pagerank,
    'Betweenness': betweenness
})

# Sort by PageRank to see the top influencers
print(centrality_df.sort_values(by='PageRank', ascending=False).head(10))


#%%

# 1. Run the Greedy Modularity algorithm
print("Detecting communities... this may take a moment.")
communities = list(community.greedy_modularity_communities(G))

# 2. Basic stats about the communities
print(f"Number of communities detected: {len(communities)}")

# 3. Print the top 5 largest communities to see if they make sense
# (We look at the first few nodes in each to see if you recognize names)
for i, comm in enumerate(communities[:10]):
    print(f"\nCommunity {i+1} (Size: {len(comm)}):")
    print(list(comm)[:20]) # Print first 10 heroes in this community
    
# 3. Link Prediction (RQ3: Which heroes are likely to team up next?)
print("\nPredicting potential new collaborations...")
# %%
import random

# 1. Get 5 random heroes from the graph
all_heroes = list(G.nodes())
random_heroes = random.sample(all_heroes, 5)

print("\nPredicting potential new collaborations for 5 random heroes:")

for hero_name in random_heroes:
    print(f"\n--- Random Sample: {hero_name} ---")
    
    # Get potential partners
    potential_partners = [n for n in G.nodes() if n != hero_name and not G.has_edge(hero_name, n)]
    
    # Run Jaccard coefficient
    preds = nx.jaccard_coefficient(G, [(hero_name, n) for n in potential_partners])
    
    # Sort and print top 3
    top_preds = sorted(list(preds), key=lambda x: x[2], reverse=True)[:5]
    for u, v, p in top_preds:
        print(f"  Predicted partner: {v} (Similarity Score: {p:.4f})")
        
# %% Visualizations
import matplotlib.pyplot as plt
import seaborn as sns


# Ensure you have your top 10 data from your previous step
top_10 = centrality_df.sort_values(by='PageRank', ascending=False).head(10)

plt.figure(figsize=(10, 6))
sns.barplot(x=top_10['PageRank'], y=top_10.index, palette='magma')
plt.title('Top 10 Influential Marvel Heroes (PageRank Analysis)')
plt.xlabel('PageRank Score')
plt.ylabel('Hero')
plt.tight_layout()
plt.show()

# 2. Plot Community Sizes

comm_sizes = [len(comm) for comm in communities]

plt.figure(figsize=(10, 6))
sns.histplot(comm_sizes, bins=20, color='teal', edgecolor='black')
plt.title('Distribution of Community Sizes')
plt.xlabel('Number of Heroes in Community')
plt.ylabel('Number of Communities')
plt.grid(axis='y', linestyle='--', alpha=0.7)
plt.tight_layout()
plt.show()
